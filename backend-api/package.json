{
  "name": "chatbot-backend",
  "version": "1.0.0",
  "description": "Bot OS Backend API",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch ../shared-types,../connectors src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:billing-foundation": "node scripts/migrate-billing-foundation.js",
    "migrate:support-audit": "node scripts/migrate-support-audit.js",
    "migrate:retire-legacy-subscriptions": "node scripts/migrate-retire-legacy-subscriptions.js",
    "migrate:platform-settings": "node scripts/migrate-platform-settings.js",
    "migrate:plan-pricing-model": "node scripts/migrate-plan-pricing-model.js",
    "migrate:workspace-limit-overrides": "node scripts/migrate-workspace-limit-overrides.js",
    "migrate:soft-delete-retention": "node scripts/migrate-soft-delete-retention.js",
    "migrate:ai-node-permission": "node scripts/migrate-ai-node-permission.js",
    "migrate:lead-forms": "node scripts/migrate-lead-forms.js",
    "migrate:lead-form-field-types": "node scripts/migrate-lead-form-field-types.js",
    "migrate:retire-lead-form-nodes": "node -r dotenv/config scripts/migrate-retire-lead-form-nodes.js dotenv_config_path=.env",
    "migrate:flow-trigger-receipts": "node scripts/migrate-flow-trigger-receipts.js",
    "migrate:template-meta-columns": "node scripts/migrate-template-meta-columns.js",
    "reencrypt:secrets": "npm run build && node scripts/reencrypt-secrets.js",
    "test:support-session-consent": "npm run build && node scripts/test-support-session-consent.js",
    "test:flow-builder-guardrails": "npm run build && node scripts/test-flow-builder-guardrails.js",
    "test:flow-handoffs": "npm run build && node scripts/test-flow-handoffs.js",
    "test:workspace-enforcement": "npm run build && node scripts/test-workspace-enforcement.js",
    "test:workspace-export": "npm run build && node scripts/test-workspace-export.js",
    "test:soft-delete-lifecycle": "npm run build && node scripts/test-soft-delete-lifecycle.js",
    "test:campaign-happy-path": "npm run build && node scripts/campaign-happy-path.js",
    "promote:account": "node scripts/promote-account.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
